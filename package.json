{
  "name": "backend",
  "module": "src/app/server.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/app/server.ts",
    "build": "bun build ./src/app/server.ts --outdir ./build",
    "start": "bun run ./build/server.js",
    "db:generate": "drizzle-kit generate:mysql",
    "db:push": "drizzle-kit push:mysql"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.4",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "mysql2": "^3.22.3",
    "nanoid": "^5.1.11",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  }
}
